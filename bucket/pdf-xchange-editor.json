{
    "version": "11.0.1.0",
    "description": "A small, fast, and feature-rich PDF viewer/editor.",
    "homepage": "https://www.pdf-xchange.com/product/pdf-xchange-editor",
    "license": {
        "identifier": "Freeware",
        "url": "https://www.tracker-software.com/PDF_VE.pdf"
    },
    "architecture": {
        "64bit": {
            "url": "https://downloads.pdf-xchange.com/11.0.1.0/PXCEditor11_Portable_x64.zip",
            "hash": "4195b2516512bbe9298272bd1fca8c8d5f546c5d21ff898ced992c338cc05049"
        },
        "32bit": {
            "url": "https://downloads.pdf-xchange.com/11.0.1.0/PXCEditor11_Portable_x86.zip",
            "hash": "8f0428a66b1bca05b95fa5096b35e68543a925eb0cdd9d5d240d755141c9a569"
        }
    },
    "pre_install": [
        "# Hardlinks cannot work properly here, as this app would create a new file instead of writing directly.",
        "'History.dat', 'Settings.dat' | ForEach-Object {",
        "    if (Test-Path \"$persist_dir\\$_\") {",
        "        Copy-Item \"$persist_dir\\$_\" \"$dir\\$_\" -Force -ErrorAction SilentlyContinue",
        "    } else {",
        "        New-Item \"$dir\\$_\" -ItemType File | Out-Null",
        "    }",
        "}"
    ],
    "bin": "PDFXEdit.exe",
    "shortcuts": [
        [
            "PDFXEdit.exe",
            "PDF-XChange Editor"
        ]
    ],
    "persist": [
        "History.dat",
        "Settings.dat"
    ],
    "pre_uninstall": [
        "# Hardlinks cannot work properly here, as this app would create a new file instead of writing directly.",
        "ensure $persist_dir",
        "'History.dat', 'Settings.dat' | ForEach-Object {",
        "    if (Test-Path \"$dir\\$_\") {",
        "        Copy-Item \"$dir\\$_\" \"$persist_dir\\$_\" -Force -ErrorAction SilentlyContinue",
        "    }",
        "}"
    ],
    "checkver": {
        "url": "https://www.pdf-xchange.com/product/pdf-xchange-editor/history/download-text-file",
        "regex": "Build ([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.pdf-xchange.com/$version/PXCEditor11_Portable_x64.zip"
            },
            "32bit": {
                "url": "https://downloads.pdf-xchange.com/$version/PXCEditor11_Portable_x86.zip"
            }
        }
    }
}
