            "hash": "8915b80bc5fc9200c6aeaee8c1a8a066e435df29cf3495fa8db3a8794c4a62e7"
        }
    },
    "pre_install": [
        "# Hardlinks cannot work properly here, as this app would create a new file instead of writing directly.",
        "'History.dat', 'Settings.dat' | ForEach-Object {",
        "    if (Test-Path \"$persist_dir\\$_\") {",
        "        Copy-Item \"$persist_dir\\$_\" \"$dir\\$_\" -Force -ErrorAction SilentlyContinue",
        "    } else {",
        "        New-Item \"$dir\\$_\" -ItemType File | Out-Null",
        "    }",
        "}"
    ],
    "bin": "PDFXEdit.exe",
    "shortcuts": [
        [
            "PDFXEdit.exe",
            "PDF-XChange Editor"
        ]
    ],
    "persist": [
        "History.dat",
        "Settings.dat"
    ],
    "pre_uninstall": [
        "# Hardlinks cannot work properly here, as this app would create a new file instead of writing directly.",
        "ensure $persist_dir",
        "'History.dat', 'Settings.dat' | ForEach-Object {",
        "    if (Test-Path \"$dir\\$_\") {",
        "        Copy-Item \"$dir\\$_\" \"$persist_dir\\$_\" -Force -ErrorAction SilentlyContinue",
        "    }",
        "}"
    ],
    "checkver": {
        "url": "https://www.pdf-xchange.com/product/pdf-xchange-editor/history/download-text-file",
        "regex": "Build ([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.pdf-xchange.com/$version/PDFXEdit10_Portable_x64.zip"
            },
            "32bit": {
                "url": "https://downloads.pdf-xchange.com/$version/PDFXEdit10_Portable_x86.zip"
            }
        }
    }
}
